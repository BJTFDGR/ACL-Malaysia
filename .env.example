# ─────────────────────────────────────────────────────
# Malaysian Data Collector — Credentials Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────

# ── Reddit API ────────────────────────────────────────
# Create a free app at: https://www.reddit.com/prefs/apps
# Choose "script" type, redirect URI can be http://localhost:8080
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=MalayDataCollector/1.0 (by u/your_reddit_username)

# ── Twitter / X Accounts (for twscrape) ──────────────
# twscrape uses real Twitter accounts (no paid API needed).
# Format: username:password:email:email_password (comma-separated for multiple)
# More accounts = higher throughput + less risk of rate-limiting.
#
# ⚠ Use dedicated/throwaway accounts, not your personal account.
TWITTER_ACCOUNTS=account1:password1:email1@gmail.com:emailpass1,account2:password2:email2@gmail.com:emailpass2
